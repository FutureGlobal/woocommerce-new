# ── WooCommerce ──────────────────────────────────────────────
WC_STORE_URL=https://cococomfort.nl
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: set in WooCommerce webhook settings for signature verification
WC_WEBHOOK_SECRET=

# ── Mabang TMS ───────────────────────────────────────────────
MABANG_BASE_URL=https://tms-api.mabangerp.com/api/
MABANG_CLIENT_ID=47777
MABANG_SUPPLIER_ID=1564
# Your Mabang CDKEY (found in TMS account settings)
MABANG_CLIENT_SECRET=your_mabang_cdkey_here
MABANG_SHOP_NAME=COCOCOMFORT
MABANG_WAREHOUSE_CODE=FGSH01
MABANG_WAREHOUSE_ID=888709
# Get channel codes from GET /api/channels after deploying
MABANG_DEFAULT_CHANNEL_CODE=

# ── Sync Schedule (cron syntax) ───────────────────────────────
ORDER_SYNC_INTERVAL=*/15 * * * *
TRACKING_SYNC_INTERVAL=*/30 * * * *
SYNC_PAGE_SIZE=50

# ── Server ───────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info
